# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ── Supabase ──────────────────────────────────────────────
# Project Settings → Data API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings → API Keys (NEW key system, 2026+)
# Publishable key (sb_publishable_...) — client-safe, replaces legacy anon key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Secret key (sb_secret_...) — SERVER ONLY, replaces legacy service_role key
SUPABASE_SECRET_KEY=sb_secret_xxx

# Direct Postgres connection — used ONLY by scripts/migrate.ts (DDL).
# Project Settings → Database → Connection string → URI (Direct, port 5432)
# Append ?sslmode=require if not already present.
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require

# ── ElevenLabs ────────────────────────────────────────────
NEXT_PUBLIC_EL_AGENT_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=

# ── NVIDIA NIM (Nemotron LLM) ─────────────────────────────
# OpenAI-compatible endpoint at https://integrate.api.nvidia.com/v1
# Used for: intent detection (nano-8b), summarisation + QA scoring (super-49b)
NVIDIA_API_KEY=

# ── OpenAI (embeddings only) ──────────────────────────────
OPENAI_API_KEY=
