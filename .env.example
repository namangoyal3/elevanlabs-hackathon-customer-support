# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ── Database (Railway Postgres + pgvector) ─────────────────
# From Railway: Postgres service → Variables tab → DATABASE_URL
# Append ?sslmode=require if Railway hasn't already.
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway?sslmode=require

# ── ElevenLabs ────────────────────────────────────────────
# Public agent ID (safe in client bundle — used by browser SDK)
NEXT_PUBLIC_EL_AGENT_ID=
# Server-only API key (KB management, server-side calls)
ELEVENLABS_API_KEY=
# HMAC secret for post-call webhook validation (Phase 4)
ELEVENLABS_WEBHOOK_SECRET=

# ── Claude / Anthropic ────────────────────────────────────
# Used for intent detection, summarisation, QA scoring
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────
# For text-embedding-3-small (KB ingestion + RAG queries).
# Replace with ElevenLabs embedding API when GA.
OPENAI_API_KEY=

# ── Optional: Clerk auth (skip for hackathon) ─────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
